{
    "name": "mimidesunya/cti.php",
    "description": "CTI Driver for PHP - Connect to Copper PDF document conversion server",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "pdf",
        "copper",
        "cti",
        "document",
        "conversion"
    ],
    "homepage": "https://github.com/mimidesunya/cti.php",
    "authors": [
        {
            "name": "Zamasoft",
            "homepage": "https://zamasoft.jp"
        }
    ],
    "require": {
        "php": ">=5.6"
    },
    "require-dev": {
        "phpdocumentor/phpdocumentor": "^3",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "CTI\\": "src/CTI/"
        },
        "files": [
            "src/Helpers.php",
            "src/CTIP2.php",
            "src/DriverManager.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/guides-*": true
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
