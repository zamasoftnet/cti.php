<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor configVersion="3">
    <title>CTI PHP Driver</title>
    <paths>
        <output>build/apidoc</output>
    </paths>
    <version number="latest">
        <api>
            <source dsn=".">
                <path>src</path>
            </source>
            <ignore hidden="true">
                <path>vendor</path>
                <path>tests</path>
            </ignore>
            <extensions>
                <extension>php</extension>
            </extensions>
            <encoding>UTF-8</encoding>
            <output>api</output>
        </api>
    </version>
</phpdocumentor>